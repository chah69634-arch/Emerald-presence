# config.yaml.example — copy to config.yaml and fill in secrets before first run.
# This file is safe to commit (no real keys).

# ── 运行模式 ──────────────────────────────────────────────────────────────────
# production: 正式运行，数据写入 data/ 根目录
# test:       单测模式，数据写入 data/test_sandbox/<id>/
mode: production

# data_prefix: 所有运行时数据的根路径。
#   生产值必须为 "data"，不要设为 test sandbox 路径。
#   如果此处出现 data/test_sandbox/...，说明 smoke test 遗留，请立即修正。
data_prefix: "data"

# ── QQ 连接 ───────────────────────────────────────────────────────────────────
qq:
  enabled: false
  host: 127.0.0.1
  port: 3001

# ── LLM ───────────────────────────────────────────────────────────────────────
llm:
  provider: deepseek          # deepseek / openai / ...
  api_key: YOUR_LLM_API_KEY
  model: deepseek-chat
  base_url: https://api.deepseek.com
  tool_call_mode: function_calling
  temperature: 1
  top_p: 0.95
  max_tokens: 4000
  frequency_penalty: 0.1

# ── Vision ────────────────────────────────────────────────────────────────────
vision:
  enabled: true
  provider: glm
  api_key: YOUR_VISION_API_KEY
  model: glm-4v-flash
  base_url: https://open.bigmodel.cn/api/paas/v4/

# ── 角色 ──────────────────────────────────────────────────────────────────────
character:
  default: Companion.json
  name: Companion
  consistency_check_every_n: 15

# ── 管理端 ────────────────────────────────────────────────────────────────────
admin:
  enabled: true
  auto_start: true
  host: 0.0.0.0
  port: 8080
  secret_key: CHANGE_ME

# ── 手机中继唤醒 ──────────────────────────────────────────────────────────────
# 任一项为空时静默禁用；中继 payload 只发信号，不含消息正文。
relay_base_url: null          # 例如 https://ntfy.example.com（无尾斜杠）
relay_topic: null             # 完整设备 topic，例如 yexuan/<user_id>/<device_token>
relay_token: null             # 后端发布凭证；不要复用 admin secret
